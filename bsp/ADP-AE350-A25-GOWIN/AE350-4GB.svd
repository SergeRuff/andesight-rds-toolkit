    <peripheral>
      <name>APB_Bridge</name>
      <displayName>APB Bridge</displayName>
      <description>APB Bridge Registers</description>
      <baseAddress>0xF0000000</baseAddress>
      <registers>
        <register>
          <name>SYSVER</name>
          <displayName>SYSVER</displayName>
          <description>ID and Revision Register</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00021101</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>ID</name>
              <displayName>ID</displayName>
              <description>ID number for  ATCAPBBRG100</description>
              <bitOffset>12</bitOffset>
              <bitWidth>20</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RevMajor</name>
              <displayName>RevMajor</displayName>
              <description>Major revision number</description>
              <bitOffset>4</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RevMinor</name>
              <displayName>RevMinor</displayName>
              <description>Minor revision number</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>Control</name>
          <displayName>Control</displayName>
          <description>Control Register</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>WBUF_EN</name>
              <displayName>WBUF_EN</displayName>
              <description>Force the write buffering for all writes</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>APB_slave_1_base_size_Register</name>
