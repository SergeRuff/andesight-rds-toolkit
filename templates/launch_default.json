{
    "configurations": [
        {
            "name": "CDT GDB Target: run GDB",
            "type": "gdbtarget",
            "request": "attach",

            "gdb": "${config:gdbScriptRunner.debugger}",
            "program": "${workspaceFolder}/${config:gdbScriptRunner.program}",
            "cwd": "${workspaceFolder}",
            "definitionPath": "${config:gdbScriptRunner.svd.path}",

            "target": {
                "type": "${config:gdbScriptRunner.target.type}",
                "parameters": [
                    "${config:gdbScriptRunner.target.host}:${config:gdbScriptRunner.target.port}"
                ]
            },

            "preConnectCommands": [
                "set logging file ${workspaceFolder}/gdb-session.log",
                "set logging overwrite on",
                "set logging redirect off",
                "set logging enabled on",
                "cd ${workspaceFolder}",
                "file ${config:gdbScriptRunner.program}"
            ],

            "initCommands": [],

            "gdbAsync": false,
            "auxiliaryGdb": false,
            "verbose": false
        },
        {
            "name": "CDT GDB Target: run script file",
            "type": "gdbtarget",
            "request": "attach",

            "gdb": "${config:gdbScriptRunner.debugger}",
            "program": "${workspaceFolder}/${config:gdbScriptRunner.program}",
            "cwd": "${workspaceFolder}",
            "definitionPath": "${config:gdbScriptRunner.svd.path}",

            "target": {
                "type": "${config:gdbScriptRunner.target.type}",
                "parameters": [
                    "${config:gdbScriptRunner.target.host}:${config:gdbScriptRunner.target.port}"
                ]
            },

            "preConnectCommands": [
                "set logging file ${workspaceFolder}/gdb-session.log",
                "set logging overwrite on",
                "set logging redirect off",
                "set logging enabled on",
                "cd ${workspaceFolder}",
                "file ${config:gdbScriptRunner.program}"
            ],

            "initCommands": [
                "source ${file}"
            ],

            "gdbAsync": false,
            "auxiliaryGdb": false,
            "verbose": false
        }
    ]
}
